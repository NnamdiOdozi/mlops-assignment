#layout python3 .venv  # this is an improvement over source .venv/bin/activate Note that i have installed the python-is-python3 library and so using python 3 or python would both work.  But to use layout you would need to do this at the start before running uv venv .venv
source .venv/bin/activate

# Project directory - single source of truth (update this if you move the project)
export PROJECT_DIR="/home/nodozi/projects/NEBIUS_MAR_2026/mlops-assignment"

# Propagate PROJECT_DIR to .env.claude for Claude shells (which can't run direnv)
if grep -q "^PROJECT_DIR=" .env.claude 2>/dev/null; then
  sed -i "s|^PROJECT_DIR=.*|PROJECT_DIR=$PROJECT_DIR|" .env.claude
else
  echo "PROJECT_DIR=$PROJECT_DIR" >> .env.claude
fi

dotenv .env
dotenv .env.claude